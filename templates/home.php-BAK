                        'bulletin_url' => $bulletin_url,
                        'notes_url' => $notes_url,
                        'video_url' => $video_url,
                        'audio_url' => $audio_url,
                    );

                }
                wp_reset_postdata();

            }
            wp_reset_query();

        }
        wp_reset_postdata();

    }
    wp_reset_query();

}
