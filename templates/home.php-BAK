date_default_timezone_set("Asia/Singapore");
foreach ($messages as $message_id) {
    //var_dump(' ===== ' );
    $message_title = get_the_title($message_id);
    $message_post_name = get_post($message_id)->post_name;
    //var_dump(' TAB =  '. $message_title);
    $week_start = date("Y-m-d", strtotime('sunday last week'));
    $week_end = date("Y-m-d", strtotime("sunday this week"));
    $day_of_week_weekly = date('w');

    $series_args = array(
        'post_type' => 'page',
        'post_status' => 'publish',
        'child_of' => $message_id,
        'post_parent' => $message_id,
        'orderby' => 'meta_value',
        'meta_key' => 'start_date',
        'order' => 'DESC',
        'posts_per_page' => 1,

    );

    $query = new WP_Query($series_args);

    //var_dump('message-id = '.$message_id);
    //echo "Last SQL-Query: {$query->request}";

    if ($query->have_posts()) {

        while ($query->have_posts()) {

            $query->the_post();
            setup_postdata($post);
            $post_series = $post;

            $message_args = array(
                'post_type' => 'page',
                'post_status' => 'publish',
                'child_of' => $post_series->ID,
                'post_parent' => $post_series->ID,
                'depth' => 1,
                'orderby' => 'meta_value',
                'meta_key' => 'article_date',
                'order' => 'DESC',
                'posts_per_page' => 1,
            );

            if ( in_array($day_of_week_weekly, array(0,6)) ) {
                //$message_args['meta_query']['value'] =  date('Y-m-d', strtotime($week_end));
                $message_args['meta_query']['value'] =  date('Ymd');
                $message_args['meta_query']['compare'] =  "=";
            } else {
                $message_args['meta_query']['value'] =  array(
                    date('Y-m-d', strtotime($week_start)),
                    date('Y-m-d', strtotime($week_end))
                );
                $message_args['meta_query']['compare'] =  "BETWEEN";
            }

            $message_args['meta_query']['key'] = 'article_date';
            $message_args['meta_query']['type'] = 'DATE';

            //var_dump('post_series->ID = '.$post_series->ID);
            //unset($message_args['meta_query']);
            $query_message = new WP_Query($message_args);

            //var_dump($query_message->have_posts()); //exit;

            if ($query_message->have_posts()) {

                //echo "Last SQL-Query: {$query_message->request}";

                while ($query_message->have_posts()) {

                    $query_message->the_post();
                    setup_postdata($post);
                    $post_message = $post;

                    $messages = get_field('message', $post_message->ID);
                    $article_date = get_field('article_date', $messages->ID);
                    //var_dump(' article_date = '. $article_date);

                    $article_title = get_field('article_title', $messages->ID);
                    $quote = get_field('quote', $messages->ID);
                    $text_refrence = get_field('text_refrence', $messages->ID);
                    $speaker = get_field('speaker', $messages->ID);
                    $chairman = get_field('chairman', $messages->ID);

                    $bulletin = get_field('bulletin', $messages->ID);
                    $bulletin_url = ($bulletin) ? wp_get_attachment_url($bulletin['id']) : '';

                    if (get_field('notes', $messages->ID)) {
                        $notes = get_field('notes', $messages->ID);
                        $notes_url = ($notes) ? wp_get_attachment_url($notes['id']) : '';
                    } else {
                        $notes_url = get_field('notes_url', $messages->ID);
                    }

                    $video_url = get_field('video_url', $messages->ID);
                    $video_cover_image = get_field('video_cover_image', $messages->ID);
                    $cover_image_url = ($video_cover_image) ? $video_cover_image['url'] : '';

                    $audio_url = get_field('audio_url', $messages->ID);

                    $tabs[] = array(
                        'tab-id' => $message_post_name,
                        'tab-label' => $message_title,

                        //videos
                        'video_url' => $video_url,
                        'video_cover_image' => $video_cover_image,
                        'cover_image_url' => $cover_image_url,

                        //resource download
                        'article_title' => $article_title,
                        'text_refrence' => $text_refrence,
                        'speaker' => $speaker,
                        'chairman' => $chairman,
                        'parent_path' => get_permalink($post_message->post_parent),
                        'parent_link' => get_the_title($post_message->post_parent),
                        'view_message' => get_permalink($post_message->ID),
                        'article_date_format' => date('d M Y', strtotime($article_date)),
                        'message_path' => get_permalink($post_message->ID),

                        //download media
