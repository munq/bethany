<?php
function get_verse_index($memory_verses, $week_unix)
{
    $i = 0;
    $found = 0;
    foreach ($memory_verses as $mk => $mv) {
        if ($mk == $week_unix) {
            $found = 1;
            break;
        } else {
            $i++;
        }
    }

    if ($found == 1) {
        return $i;
    } else {
        return 0;
    }
}

function get_rearranged_verses($array, $key)
{
    while ($key > 0) {
        $temp = array_shift($array);
        $array[] = $temp;
        $key--;
    }
    return $array;
}

function get_previous_verse($verses, $day_of_week)
{
    if ( count($verses) == 0) {
        return 0;
    }

    $i = 0;
    $verses_count = count($verses);
    $days = $day_of_week;
    foreach ($verses as $mk => $mv) {
        if ($i < $verses_count) {
            //echo "\n"; var_dump('mk = '.date("d F Y", $mk));

            $last_sunday = strtotime('-' . $days . ' days');
            $last_sunday = strtotime(date("d F Y", $last_sunday));
            //echo "\n"; var_dump('last_sunday = '.date("d F Y", $last_sunday));

            $index = get_verse_index($verses, $last_sunday);
            //var_dump('return index = '.$index);

            if ($index > 0) {
                return $index;
            }

            $days = $days + 7;
            $i++;
        }
    }

}
